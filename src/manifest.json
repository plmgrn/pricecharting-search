{
  "manifest_version": 3,
  "name": "Search on PriceCharting",
  "version": "1.1.1",
  "description": "Right-click selected text to look up its price on PriceCharting.com.",
  "homepage_url": "https://github.com/plmgrn/pricecharting-search",
  "author": "Otto Palmgren",
  "omnibox": { "keyword": "pchart" },
  "commands": {
    "search-selection": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Search PriceCharting for selected text"
    }
  },
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "icons": {
    "16": "icons/pricecharting-search_16x16.png",
    "32": "icons/pricecharting-search_32x32.png",
    "48": "icons/pricecharting-search_48x48.png",
    "64": "icons/pricecharting-search_64x64.png",
    "128": "icons/pricecharting-search_128x128.png"
  },
  "action": {
    "default_title": "Search on PriceCharting — settings",
    "default_icon": {
      "16": "icons/pricecharting-search_16x16.png",
      "32": "icons/pricecharting-search_32x32.png",
      "48": "icons/pricecharting-search_48x48.png"
    }
  },
  "background": {
    "service_worker": "background/index.js",
    "scripts": ["background/index.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pricecharting-search@plmgrn.users.noreply.github.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
